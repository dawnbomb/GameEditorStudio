<UserControl x:Class="GameEditorStudio.DataTableEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GameEditorStudio"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1400">
    

    <Grid x:Name="EditorBack">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="500"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Column="0" Grid.Row="0" Margin="0,3,0,3" LastChildFill="False" >
            <Button Content="I-ID" DockPanel.Dock="Left" Click="ToggleItemIDNumberVisibility" Margin="1,0,5,0" ToolTip="Toggles item ID numbers. &#xD;&#xA;ID numbers are shown using the real, internal game data order, not the order you arrange them in. &#xD;&#xA;If you didn't know, you can drag items around and reorder them!&#xD;&#xA;Anyway, because the ID numbers can become almost useless, you have the option to turn them off."/>
            <Button Content="アA" Width="45" DockPanel.Dock="Left" x:Name="TranslationToggle" Style="{DynamicResource ButtonError}"  Click="ToggleTranslationPanel" Margin="0,0,2,0" ToolTip="Toggles the translation panel.&#xD;&#xA;This is an upcoming feature, and will be useful for people making english patches."/>

        </DockPanel>
        <DockPanel Grid.Column="2" Grid.Row="0" Margin="0,3,0,3" LastChildFill="False" >
            <Button Content="🔍" DockPanel.Dock="Left" x:Name="EntrySymbologyToggle"  Click="ToggleEntrySymbology" Margin="2,0,2,0" ToolTip="Toggles Symbology. &#xD;&#xA;Symbology tries to tell you information useful for discovering what an entry byte actually does. &#xD;&#xA;You can mouseover an entry symbol to learn more detailed information." Width="42"/>
            <Button Content="E-ID" Visibility="Collapsed" DockPanel.Dock="Left" x:Name="EntryAddressButton"  Click="EntryAddressToggle" Margin="2,0,2,0" ToolTip="Toggles the display of Entry ID numbers. &#xD;&#xA;The number represents what byte # the entry is, for the row it's in.&#xD;&#xA;For nerds, this is a Byte's Offset Value. " Width="58"/>
            <Button DockPanel.Dock="Left" x:Name="EntryAddressTypeButton" Content="Dec" Width="50" Click="EntryAddressType" Margin="2,0,2,0" ToolTip="Changes the Entry ID number between displaying... &#xD;&#xA;in Decimal (Numbers 0~9) &#xD;&#xA;and Hex (Numbers 00~FF). "/>
            <TextBox DockPanel.Dock="Left" x:Name="EntryAddressOffsetTextbox" Text="0" Width="35" Margin="2,1,2,1" KeyDown="EntryOffsetTextboxKeyDown" ToolTip="This textbox value (after pressing enter) will make each entry-ID APPEAR &#xD;as if it's offset ID was +/- X number. Such as -3 or +5. &#xA;&#xA;It does not actually change the offset of any entrys, only the appearence." />
            <Button Content="👁"  DockPanel.Dock="Left" x:Name="EntryHiddenToggle"   Click="ToggleHiddenEntrys" Margin="2,0,2,0" ToolTip="Toggles the visibility of hidden entrys. &#xD;&#xA;When visable, a hidden entry will appear red. &#xA;&#xA;Note 1: &#xA;Entrys that represent name or description text are forced to hidden, &#xA;and moved into a 'Hidden' category. &#xA;&#xA;Note 2:&#xA;If all entrys in a category are set to hidden, the category itself also becomes hidden. &#xA;You can use this to organize your hidden entrys away from the normal ones." />
            <Button Content="^^" DockPanel.Dock="Left" x:Name="UpDownToggleButton"  Click="UpDownToggle" Margin="2,0,2,0" ToolTip="Toggles the movement mode when moving entrys. &#xD;&#xA;When UP, entrys will appear above the target. &#xD;When DOWN, entrys will appear below the target. &#xD;&#xD;I couldn't decide if i wanted them to appear above or below, &#xD;so i just coded in both and i let you decide. :) &#xD;&#xD;(You can move an entry by clicking and dragging it over &#xD;another entry, or some empty space)" Width="42"/>
            <Button Content="EV"  DockPanel.Dock="Left" x:Name="EntryVisibilityToggle"   Click="ToggleEntryFrameVisibility" Margin="2,0,2,0" Style="{DynamicResource ButtonError}" ToolTip="Toggles if Entry 'frame' is visible. &#xD;Turn off for a 'clean' look." />

            <Button Content="Grid"  DockPanel.Dock="Left" x:Name="DebugUpdateALLGrid"   Click="UpdateALLGrids"  Style="{DynamicResource ButtonError}" Margin="2,0,2,0" ToolTip="Makes EVERYTHING visable. &#xD;&#xA;This button only exists in debug mode.&#xA;Mostly it just shows merged entrys." />
            <Button Content="👁️‍🗨️"  DockPanel.Dock="Left" x:Name="DebugShowALL"   Click="ToggleDebugShowALL" Margin="2,0,2,0" ToolTip="Makes EVERYTHING visable. &#xD;&#xA;This button only exists in debug mode.&#xA;Mostly it just shows merged entrys." />

            <Button Content="Spreadsheet" DockPanel.Dock="Left" x:Name="SpreadsheetToggle"   Click="ToggleSpreadsheet" Margin="2,0,2,0" ToolTip="Lets you view everything like a spreadsheet. &#xD;&#xA;Column colors are based on entry colors." />


            <Button Content="Help / Tutorial"  DockPanel.Dock="Right" x:Name="HelpButton"   Click="HelpButtonClicked" Margin="2,0,2,0" Width="161"/>
        </DockPanel>


        <Grid x:Name="MainGrid" DockPanel.Dock="Top" Visibility="Collapsed">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            
        </Grid>


        <local:TheLeftBar x:Name="LeftBar"  Grid.Column="0" Grid.Row="1" />


        <GridSplitter Style="{DynamicResource SplitterVertical}"  Grid.Column="1" Grid.Row="1"  Width="10"/>        
        
        

        <GridSplitter Style="{DynamicResource SplitterVertical}"  Grid.Column="3" Grid.Row="1"  Width="10"/>
        
        <local:DTRightBar x:Name="RightBar"  Grid.Column="5" Grid.Row="1" />

        <Grid Grid.Column="2" Grid.Row="1"   >
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="60"/>
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ContentControl Grid.Row="0">
                <ScrollViewer Name="TheScrollviewer" HorizontalScrollBarVisibility="Auto" PreviewMouseWheel="ScrollSpeed" >
                    <DockPanel Name="EditorsPanel" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Style="{DynamicResource BorderDock}" LastChildFill="True" >
                        <Label Content="NOTE: THIS IS CLEARED WHEN UI IS GENERATED&#xD;&#xA;&#xD;&#xA;PS:&#xD;&#xA;DO NOT FIX THE BACKGROUND COLOR ERROR&#xD;&#xA;BECAUSE IT IMPLYS USERS CAN DROP ENTRYS&#xD;&#xA;TO THE BOTTOM, WHEN THEY CAN NOT." DockPanel.Dock="Top"/>
                        <ComboBox Width="100" DockPanel.Dock="Top">
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                            <ComboBoxItem Content="ReadMe" />
                        </ComboBox>
                        <Label Content="NOTE: THIS IS CLEARED WHEN UI IS GENERATED&#xD;&#xA;&#xD;&#xA;PS:&#xD;&#xA;DO NOT FIX THE BACKGROUND COLOR ERROR&#xD;&#xA;BECAUSE IT IMPLYS USERS CAN DROP ENTRYS&#xD;&#xA;TO THE BOTTOM, WHEN THEY CAN NOT." DockPanel.Dock="Bottom"/>
                        <Label Content="NOTE: THIS IS CLEARED WHEN UI IS GENERATED&#xD;&#xA;&#xD;&#xA;PS:&#xD;&#xA;DO NOT FIX THE BACKGROUND COLOR ERROR&#xD;&#xA;BECAUSE IT IMPLYS USERS CAN DROP ENTRYS&#xD;&#xA;TO THE BOTTOM, WHEN THEY CAN NOT." DockPanel.Dock="Bottom"/>


                        <Label Content="NOTE: THIS IS CLEARED WHEN UI IS GENERATED&#xD;&#xA;&#xD;&#xA;PS:&#xD;&#xA;DO NOT FIX THE BACKGROUND COLOR ERROR&#xD;&#xA;BECAUSE IT IMPLYS USERS CAN DROP ENTRYS&#xD;&#xA;TO THE BOTTOM, WHEN THEY CAN NOT." DockPanel.Dock="Bottom"/>
                        <Label Content="NOTE: THIS IS CLEARED WHEN UI IS GENERATED&#xD;&#xA;&#xD;&#xA;PS:&#xD;&#xA;DO NOT FIX THE BACKGROUND COLOR ERROR&#xD;&#xA;BECAUSE IT IMPLYS USERS CAN DROP ENTRYS&#xD;&#xA;TO THE BOTTOM, WHEN THEY CAN NOT." DockPanel.Dock="Bottom"/>
                        <Label Content="NOTE: THIS IS CLEARED WHEN UI IS GENERATED&#xD;&#xA;&#xD;&#xA;PS:&#xD;&#xA;DO NOT FIX THE BACKGROUND COLOR ERROR&#xD;&#xA;BECAUSE IT IMPLYS USERS CAN DROP ENTRYS&#xD;&#xA;TO THE BOTTOM, WHEN THEY CAN NOT." DockPanel.Dock="Bottom"/>
                    </DockPanel>
                </ScrollViewer>
            </ContentControl>

            <ContentControl Name="DescriptionsBottomBar" Grid.Row="1" Margin="0,10,0,0">
                <DockPanel x:Name="DescriptionsPanel">
                    <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                        <DockPanel Style="{DynamicResource ContentBar}">
                            <Label Content="Description" FontWeight="Bold" Margin="5,0,0,0" />
                            <Label Name="DescriptionCharCount" Content="Character Count.." HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Top"  />
                        </DockPanel>
                    </Border>

                </DockPanel>
            </ContentControl>

        </Grid>

    </Grid>

</UserControl>
