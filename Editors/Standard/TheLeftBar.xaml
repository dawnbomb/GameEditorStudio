<UserControl x:Class="GameEditorStudio.TheLeftBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GameEditorStudio"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="250">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0">
            <DockPanel>
                <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                    <DockPanel Style="{DynamicResource ContentBar}">
                        <Label Name="ItemsLabel" Content="Items" FontWeight="Bold"/>
                        <TextBox Name="SearchBar" Margin="15,4,4,4" Text="🔎 Search....." TextChanged="SearchBarTextChanged"/>
                    </DockPanel>
                </Border>
                
                <TreeView Name="ItemsTree"  SelectedItemChanged="ItemsTreeSelectedItemChanged" />
            </DockPanel>
        </ContentControl>

        <GridSplitter Style="{DynamicResource SplitterHorizontal}" Grid.Row="1" Height="14"   />

        <ContentControl Grid.Row="2" >
            <DockPanel>
                <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                    <DockPanel Style="{DynamicResource ContentBar}">
                        <Label Content="Info" FontWeight="Bold"/>

                        <Label Content="Chars: XX / YY" Name="LabelCharacterCount" FontWeight="Bold" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                    </DockPanel>
                </Border>                
                <Grid Margin="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Content="Name" Grid.Row="0" Grid.Column="0"/>
                    <Border Grid.Row="0" Grid.Column="0" Margin="3,0,4,3" BorderThickness="0,0,0,2" BorderBrush="#FFA4A4A4" ToolTip="This lets you edit the name of an item. &#xA;BE CAREFUL ABOUT USING SYMBOLS THE GAME DOESN'T RECONIZE!!! &#xA;Also: most games have a character limit for name length.&#xA; &#xA;If you want to give it a Nickname, use a note instead!"/>
                    <TextBox x:Name="ItemNameTextbox" Grid.Row="0" Grid.Column="1" Width="Auto" Margin="3" PreviewKeyDown="ItemNameboxPreviewKeyDown" KeyDown="ItemNameboxKeyDown" TextChanged="ItemNameboxTextChanged"/>

                    <Label Content="Note" Grid.Row="1" Grid.Column="0"/>
                    <Border Grid.Row="1" Grid.Column="0" Margin="3,0,4,3" BorderThickness="0,0,0,2" BorderBrush="#FFA4A4A4" ToolTip="Notes (to the right) appear as &#xA;orange text next to the item. &#xA;They do not save to the game, but &#xA;are useful for quick notes. &#xA; &#xA;For detailed notes, use the box below. &#xA;It creates a tooltip for the item. &#xA;Don't be afraid to have a LOT of text!. &#xA; &#xA;Note that BOTH types of notes are a part of the editor, &#xA;they are not a part of your project. &#xA;IE other people can see them when sharing a workshop."/>
                    <TextBox x:Name="ItemNoteTextbox" Grid.Row="1" Grid.Column="1" Margin="3" KeyDown="ItemNoteboxKeyDown" />

                    <TextBox x:Name="ItemNotepadTextbox" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="3" TextChanged="NotepadTextChanged" ToolTip="This is where you write a tooltip for the item.&#xD;&#xA;Items with a tooltip appear underlined, and hovering the mouse on them shows the tooltip.&#xD;&#xA;It also supports linebreaks (the enter key), go nuts.&#xD;&#xA;Item Tooltips are part of the editor, not a mod / project, but support for that is coming later." />
                </Grid>
            </DockPanel>
        </ContentControl>
        

        <!--<GridSplitter x:Name="TranslationSplitter" Style="{DynamicResource SplitterHorizontal}" Grid.Row="3"   />-->

        <Border Grid.Row="4" x:Name="TranslationsPanelBorder" Visibility="Collapsed"> 
            <local:TranslationsPanel x:Name="TranslationsPanel"  />
        </Border>

    </Grid>
</UserControl>
