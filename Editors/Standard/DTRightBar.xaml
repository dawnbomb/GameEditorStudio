                <TabItem Header="Auto Mod">
                    <Border>
                        <DockPanel>
                            <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                                <DockPanel Style="{DynamicResource ContentBar}"  LastChildFill="False">
                                    <Label Content="Automatically mod the game!" FontWeight="Bold" DockPanel.Dock="Left"/>
                                </DockPanel>
                            </Border>

                            <Grid  Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="165*"/>
                                    <ColumnDefinition Width="113*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>

                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>


                                <Label Content="Instant Mod: Apply a math formula to EVERY &#xD;&#xA;item! Examples: 50% MP Costs,&#xD;&#xA;200% Enemy HP, 0% Buy Prices, etc." Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" />

                                <Label Content="Action " Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="1" />
                                <ComboBox x:Name="FormulaComboBox" Grid.Row="3" Grid.Column="1" Margin="3,3,3,3" Grid.ColumnSpan="1">
                                    <ComboBoxItem Content="Multiply" IsSelected="True"/>
                                    <ComboBoxItem Content="Add" Foreground="#FF440F0F"/>
                                    <ComboBoxItem Content="Subtract" Foreground="#FF2B0909"/>
                                </ComboBox>

                                <Label Content="Action Value " Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="1" />
                                <TextBox x:Name="FormulaTextBox" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Text="100%" Margin="3,3,3,3" Grid.ColumnSpan="1"/>

                                <Label Content="MAX"  Grid.Row="5" Grid.Column="0"/>
                                <Border Grid.Row="5" Grid.Column="0" Margin="3,0,150,3" BorderThickness="0,0,0,2" BorderBrush="#FFA4A4A4" ToolTip="This lets you set a Maximum value. &#xA;If it's empty, there is no maximum.&#xA; &#xA;Note: The true max is based on the byte size.&#xA;BEWARE: It does not yet account for the max being cut in half &#xA;because of negative values (signed bytes)."/>
                                <TextBox x:Name="FormulaMaxTextBox" Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" Margin="3,3,3,3" Grid.ColumnSpan="1" />


                                <Label Content="MIN"  Grid.Row="6" Grid.Column="0"/>
                                <Border Grid.Row="6" Grid.Column="0" Margin="3,0,150,3" BorderThickness="0,0,0,2" BorderBrush="#FFA4A4A4" ToolTip="This lets you set a Minimum value. &#xA;If it's empty, there is no minimum.&#xA; &#xA;Note: The true minimum is always 0.&#xA;(Does not yet support negative numbers)"/>
                                <TextBox x:Name="FormulaMinTextBox"  Grid.Row="6" Grid.Column="1"  TextWrapping="Wrap" Margin="3,3,3,3" Grid.ColumnSpan="1" />


                                <Label Content="Skip last X items: " Grid.Row="7" Grid.Column="0"/>
                                <Border Grid.Row="7" Grid.Column="0" Margin="3,0,20,3" BorderThickness="0,0,0,2" BorderBrush="#FFA4A4A4" ToolTip="This will NOT mod the bottom X items in the item list. &#xA;I know i should code in something better, &#xA;but this was easy to do and i have other parts&#xA;of the program to be working on."/>
                                <TextBox x:Name="FormulaDoNotModTextBox" Grid.Row="7" Grid.Column="1" TextWrapping="Wrap" Text="0" Margin="3,3,3,3" Grid.ColumnSpan="1" />

                                <Button Content="Apply to all items" Grid.Row="8" Grid.Column="1" Click="ApplyFormulaToEntryAcrossAllItems" Grid.ColumnSpan="2"/>
                                <Label Content="    SAVE FIRST!    " Grid.Row="8" Grid.Column="0" Foreground="#FFFDA200"/>
                                <Grid Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="3">
                                    <Label Content="`Multiply` Must always end in a %. &#xA;(50%  120%  300%  70%)" HorizontalAlignment="Left" Margin="10,2,0,0" VerticalAlignment="Top"/>
                                    <Label Content="Result rounds to nearest number." HorizontalAlignment="Left" Margin="11,52,0,0" VerticalAlignment="Top"/>
                                    <Label Content="This doesn't support negative values yet!&#xD;&#xA;Mostly because i'm to lazy to code &#xD;&#xA;it right now. It can be added later :&gt;" HorizontalAlignment="Center" Margin="0,136,0,0" VerticalAlignment="Top" Width="470"/>
                                </Grid>



                            </Grid>
                        </DockPanel>
                    </Border>
                </TabItem>
