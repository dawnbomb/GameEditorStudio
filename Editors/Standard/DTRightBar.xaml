<UserControl x:Class="GameEditorStudio.DTRightBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GameEditorStudio"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="500">
    <Grid Name="EastPanel" Style="{DynamicResource BorderGrid}">

        <!--<Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>-->

        <ContentControl  >
            <TabControl Name="MainTabControl" BorderThickness="0" >
                <TabItem Name="GeneralTab" Header="General">
                    <DockPanel Name="GeneralPanel" LastChildFill="True" Grid.Row="0" Margin="0,0,0,0" Background="Transparent" >
                        <ScrollViewer DockPanel.Dock="Top" Name="WhyDoIHaveABlueBackgroundColor" VerticalScrollBarVisibility="Auto">
                            <TabControl Name="TabTest" DockPanel.Dock="Top" BorderThickness="0">
                                <TabItem Name="EditorTabItem" Header="Editor" Margin="0,0,0,0" FontSize="18"  Padding="9,0,9,0" BorderThickness="1,0,1,0">
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,0">



                                        <Border DockPanel.Dock="Top"  >
                                            <DockPanel Margin="0,0,0,3">
                                                <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                                                    <DockPanel Style="{DynamicResource ContentBar}">
                                                        <Label Content="Editor" FontWeight="Bold"  Margin="5,0,0,0" />
                                                    </DockPanel>
                                                </Border>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="5"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>

                                                    </Grid.RowDefinitions>


                                                    <Label Content="Name" Grid.Row="0" Grid.Column="1" />
                                                    <TextBox x:Name="PropertiesTextboxEditorName" Grid.Row="0" Grid.Column="2" Margin="3,3,3,3" TextWrapping="NoWrap"  KeyDown="TextboxChangeEditorName"/>

                                                    <Label Content="Icon" Grid.Column="1"  Grid.Row="1" Visibility="Collapsed"/>
                                                    <Button Name="IconManagerButton" Content="Icon Manager" Visibility="Collapsed" Grid.Row="1" Grid.Column="2" Margin="3,0,0,0" Height="25" Width="115"  Click="OpenIconManager" HorizontalAlignment="Left"/>



                                                </Grid>
                                            </DockPanel>
                                        </Border>



                                        <Border DockPanel.Dock="Top">
                                            <DockPanel>
                                                <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                                                    <DockPanel Style="{DynamicResource ContentBar}" DockPanel.Dock="Top"  LastChildFill="False">
                                                        <Label Content="Name Table" FontWeight="Bold" Margin="5,0,0,0"  />
                                                        <Button Name="NameTableManagerButton" Content="Name Table Manager" Margin="3,3,10,3" Width="200" DockPanel.Dock="Right" Click="OpenTextTableManagerForNameTable"/>
                                                    </DockPanel>
                                                </Border>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="5"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Label Content="File Location" Grid.Column="1" Grid.Row="0"  />
                                                    <TextBox Grid.Row="0" Grid.Column="2" Margin="3" x:Name="NameTableFileBox"  TextWrapping="NoWrap" IsEnabled="False" />


                                                    <Label Name="LabelCharacterSet" Content="Character Set" Grid.Row="1" Grid.Column="1" Margin="0"/>
                                                    <ComboBox x:Name="PropertiesEditorNameTableCharacterSetDropdown" Grid.Row="1" Grid.Column="2" Margin="3" DropDownClosed="EditorCharacterSetDropdownClose">
                                                        <ComboBoxItem Content="ASCII+ANSI"/>
                                                        <ComboBoxItem Content="Shift-JIS"/>
                                                    </ComboBox>

                                                    <Label Name="LabelStart" Content="Start Byte" Grid.Row="2" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesEditorNameTableStartByte" Grid.Row="2" Grid.Column="2" Margin="3"  TextWrapping="Wrap" Text="Name Start Byte"  KeyDown="ChangeNameTableStartByte"/>

                                                    <Label Name="LabelRowSize" Content="Row Size" Grid.Row="3" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesEditorNameTableRowSize" Grid.Row="3" Grid.Column="2" Margin="3" TextWrapping="Wrap" Text="Row Size"  KeyDown="ChangeNameTableRowSize"/>

                                                    <Label Name="LabelTextSize" Content="Text Size" Grid.Row="4" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesEditorNameTableTextSize" Grid.Row="4" Grid.Column="2" Margin="3" TextWrapping="Wrap" Text="Text Size" KeyDown="ChangeNameTableTextSize"/>

                                                    <Label Content="First Name #" Grid.Row="5" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesEditorFirstNameNumber" Grid.Row="5" Grid.Column="2" Margin="3" TextWrapping="Wrap" Text="1"  KeyDown="ChangeNameTableFirstNameDisplayNumber"/>

                                                    <Label Content="Name Count" Grid.Row="6" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesEditorNameCount" Grid.Row="6" Grid.Column="2" Margin="3" TextWrapping="Wrap" Text="Item Count"  KeyDown="ChangeNameTableNameCount"/>

                                                    <Label Content="From Output:" Grid.Row="7" Grid.Column="1" Margin="0"/>
                                                    <DockPanel Grid.Row="7" Grid.Column="2" Grid.ColumnSpan="1" Margin="0,3,0,3" Background="Transparent" LastChildFill="False">
                                                        <Button Name="BtnNameTblOutputOpenHxD" Content="Open with HxD" Margin="0,2,10,2" Width="150" Height="28" DockPanel.Dock="Left" Click="OpenNameTableInHxD"/>
                                                        <Button Name="BtnNameTblOutputOpen010" Content="Open with 010" Margin="3,2,0,2" Width="150" Height="28" DockPanel.Dock="Right" Click="OpenNameTableIn010"/>

                                                    </DockPanel>
                                                </Grid>
                                            </DockPanel>
                                        </Border>

                                        <Border DockPanel.Dock="Top">
                                            <DockPanel>
                                                <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                                                    <DockPanel Style="{DynamicResource ContentBar}" DockPanel.Dock="Top" LastChildFill="False" >
                                                        <Label Content="Data Table" FontWeight="Bold" Margin="5,0,0,0" DockPanel.Dock="Left" />
                                                        <Button Name="DataTableManagerButton" Content="Data Table Manager" Margin="3,3,10,3" Width="200" DockPanel.Dock="Right" Click="OpenDataTableManagerForDataTable"/>
                                                    </DockPanel>
                                                </Border>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="5"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>


                                                    <Label Content="File Location" Grid.Column="1" Grid.Row="0"  />
                                                    <TextBox Grid.Row="0" Grid.Column="2" Margin="3" x:Name="DataTableFileBox" TextWrapping="NoWrap" IsEnabled="False" />

                                                    <Label Content="Start Byte" Grid.Column="1" Grid.Row="1" />
                                                    <TextBox Grid.Row="1" Grid.Column="2" Margin="3" x:Name="PropertiesEditorTableStart" TextWrapping="Wrap" IsEnabled="True" KeyDown="ChangeEditorMainTableStartByte"/>

                                                    <Label Content="Row Size" Grid.Column="1" Grid.Row="2" />
                                                    <TextBox Grid.Row="2" Grid.Column="2" Margin="3" x:Name="PropertiesEditorTableWidth" TextWrapping="Wrap" IsEnabled="False"/>

                                                    <Label Content="Input Folder" Grid.Column="1"  Grid.Row="3"/>
                                                    <DockPanel Grid.Row="3" Grid.Column="2" Margin="3,3,3,3" Background="Transparent">
                                                        <Button Name="OpenInputLocationButton" Content="Open" Grid.Row="1" Grid.Column="2" Margin="3,0,0,0" Height="30" DockPanel.Dock="Right" Click="OpenWorkshopInputButton" Width="60"/>
                                                        <TextBox x:Name="PropertiesEditorReadGameDataFrom" Grid.Row="1" Grid.Column="2" Margin="0" TextWrapping="NoWrap"  VerticalAlignment="Center" Text="Input" />
                                                    </DockPanel>

                                                    <Label Content="Output Folder"  Grid.Row="4" Grid.Column="1" />
                                                    <DockPanel Grid.Row="4" Grid.Column="2" Margin="3,3,3,3" Background="Transparent">
                                                        <Button Name="OpenOutputLocationButton" Content="Open" Grid.Row="1" Grid.Column="2" Margin="3,0,0,0" Height="30" DockPanel.Dock="Right" Click="OpenWorkshopOutputButton" Width="60"/>
                                                        <TextBox x:Name="EditorOutputLocationTextbox" Grid.Row="2" Grid.Column="2"  TextWrapping="NoWrap"  VerticalAlignment="Center" Text="Output"/>

                                                    </DockPanel>

                                                    <Label Content="From Output:" Grid.Row="5" Grid.Column="1" Margin="0"/>
                                                    <DockPanel Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="1" Margin="0,3,0,3" Background="Transparent" LastChildFill="False">
                                                        <Button Name="BtnDataTblOutputOpenHxD" Content="Open with HxD" Margin="0,2,10,2" Width="150" Height="28" DockPanel.Dock="Left" Click="OpenDataTableInHxD"/>
                                                        <Button Name="BtnDataTblOutputOpen010" Content="Open with 010" Margin="3,2,0,2" Width="150" Height="28" DockPanel.Dock="Right" Click="OpenDataTableIn010"/>

                                                    </DockPanel>
                                                    <Label Content="Support for changing Data Table data will be&#xA;added in a post-release update." Grid.Column="1" Grid.Row="6" Grid.ColumnSpan="2"/>
                                                </Grid>
                                            </DockPanel>
                                        </Border>

                                        <Border>
                                            <DockPanel>
                                                <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                                                    <DockPanel Style="{DynamicResource ContentBar}">
                                                        <Label Content="Description" FontWeight="Bold" Margin="5,0,0,0" />
                                                        <Button Name="DescriptionTableManagerButton" Content="Description Manager" Click="OpenDescriptionManager" HorizontalAlignment="Right" Margin="0,2,5,2" VerticalAlignment="Top"  Width="220" Height="30"/>
                                                    </DockPanel>

                                                </Border>
                                                <Grid>

                                                </Grid>
                                            </DockPanel>
                                        </Border>





                                    </DockPanel>
                                </TabItem>
                                <TabItem Name="CategoryTabItem" Header="Row" Margin="0,0,1,0" FontSize="18"  Padding="9,0,9,0" BorderThickness="1,0,1,0">
                                    <DockPanel  >
                                        <Border DockPanel.Dock="Top"  >
                                            <DockPanel Margin="0,0,0,3">
                                                <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                                                    <DockPanel Style="{DynamicResource ContentBar}" Height="23"  MinHeight="0" Margin="0,0,0,5" >
                                                        <Label Content="Category" FontWeight="Bold" Margin="5,-5,0,-5"  />
                                                    </DockPanel>
                                                </Border>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="5"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>


                                                    <Label Content="Name" Grid.Row="0" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesRowNameBox" Grid.Row="0" Grid.Column="2" Margin="3" Text="New Category" TextWrapping="Wrap"  KeyDown="PropertiesRowNameBox_KeyDownEnter"/>

                                                    <Label Content="Tooltip" Grid.Row="1" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesRowTooltipBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" MinHeight="100" Margin="3" TextWrapping="Wrap" AcceptsReturn="True" TextChanged="PropertiesRowTooltipBox_TextChanged"/>

                                                    <Label Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="1" Content="Note:" HorizontalAlignment="Left" Margin="3,0,3,3" />
                                                    <Label Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="1" Content="Empty categories do not get saved. &#xA;but if you want them gone NOW, &#xA;right click the name -&gt; 'Delete'." Margin="3,0,0,3" />

                                                    <Label Name="DebugCatLabelRows" Grid.Row="4" Grid.Column="1" Content="Rows" HorizontalAlignment="Left" Margin="5,0,0,0"  VerticalAlignment="Top" IsEnabled="False"/>
                                                    <Label Name="DebugCatLabelColumns" Grid.Row="5" Grid.Column="1" Content="Columns" HorizontalAlignment="Left" Margin="5,0,0,0"  VerticalAlignment="Top" IsEnabled="False"/>
                                                    <TextBox Name="DebugCatTextboxRows" Grid.Row="4" Grid.Column="2" HorizontalAlignment="Left" Margin="0,2,0,0"  TextWrapping="Wrap" Text="Debug Mode" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
                                                    <TextBox Name="DebugCatTextboxColumns" Grid.Row="5" Grid.Column="2" HorizontalAlignment="Left" Margin="0,2,0,0"  TextWrapping="Wrap" Text="Debug Mode" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
                                                </Grid>
                                            </DockPanel>
                                        </Border>

                                    </DockPanel>
                                </TabItem>
                                <TabItem Name="GroupTabItem" Header="Group" Margin="0,0,1,0" FontSize="18"  Padding="9,0,9,0" BorderThickness="1,0,1,0">
                                    <DockPanel  >

                                        <Border DockPanel.Dock="Top"  >
                                            <DockPanel Margin="0,0,0,3">
                                                <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                                                    <DockPanel Style="{DynamicResource ContentBar}" Height="23"  MinHeight="0" Margin="0,0,0,5" >
                                                        <Label Content="Group" FontWeight="Bold" Margin="5,-5,0,-5"  />
                                                    </DockPanel>
                                                </Border>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="5"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Label Content="Name" Grid.Row="0" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesGroupNameBox" Grid.Row="0" Grid.Column="2" Margin="3" Text="New Group" TextWrapping="Wrap"  KeyDown="PropertiesGroupNameTextBox_KeyDown"/>

                                                    <Label Content="Style" Grid.Row="1" Grid.Column="1" Margin="0"/>
                                                    <ComboBox x:Name="PropertiesGroupStyle" Grid.Row="1" Grid.Column="2" Margin="3" Text="New Group" IsEnabled="False">
                                                        <ComboBoxItem Content="Name is on top" IsSelected="True"/>
                                                        <ComboBoxItem Content="Name is on the line" />
                                                        <ComboBoxItem Content="Name is inside" />
                                                    </ComboBox>

                                                    <Label Content="Tooltip" Grid.Row="2" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesGroupTooltipBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Height="100" Margin="3" Text="" AcceptsReturn="True" TextWrapping="Wrap"  TextChanged="PropertiesGroupTooltipTextBox_TextChanged"/>
                                                    <Label Grid.Row="4" Grid.Column="1" Content="Tip:" HorizontalAlignment="Left" Margin="3,3,3,3"  VerticalAlignment="Top"/>
                                                    <Label Grid.Row="4" Grid.Column="2" Content="If every entry is set to hidden, &#xA;the group also becomes hidden."  Margin="0,0,0,0"  VerticalAlignment="Top"/>

                                                    <Label Content="Column Span" Grid.Row="5" IsEnabled="False" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesGroupColumnSpan" IsEnabled="False" Grid.Row="5" Grid.Column="2" Margin="3" Text="" TextWrapping="Wrap"  KeyDown="PropertiesGroupNameTextBox_KeyDown"/>

                                                    <Label Content="Row Span" Grid.Row="6" IsEnabled="False" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesGroupRowSpan" IsEnabled="False" Grid.Row="6" Grid.Column="2" Margin="3" Text="" TextWrapping="Wrap"  KeyDown="PropertiesGroupNameTextBox_KeyDown"/>

                                                    <Label Content="Primary Color" Grid.Row="7" Grid.Column="1" />
                                                    <Label Content="(Upcoming feature)" Grid.Row="7" Grid.Column="2" />
                                                    <Label Content="Secondary Color"  Grid.Row="8" Grid.Column="1" />
                                                    <Label Content="(Upcoming feature)" Grid.Row="8" Grid.Column="2" />
                                                </Grid>
                                            </DockPanel>
                                        </Border>
                                    </DockPanel>
                                </TabItem>
                                <TabItem Name="EntryTabItem" Header="Entry" Margin="0,0,0,0" FontSize="18"  Padding="9,0,9,0" BorderThickness="1,0,1,0">
                                    <DockPanel >
                                        <Border DockPanel.Dock="Top">
                                            <DockPanel>
                                                <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                                                    <DockPanel Style="{DynamicResource ContentBar}"  >
                                                        <Label Content="Entry" FontWeight="Bold" Margin="5,0,0,0"  />
                                                    </DockPanel>
                                                </Border>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="5"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>

                                                    </Grid.RowDefinitions>


                                                    <Label Content="Name" Grid.Row="0" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesNameBox" Grid.Row="0" Grid.Column="2" Margin="3" TextWrapping="Wrap"  KeyDown="PropertiesEntryNameBox_KeyDown"/>



                                                    <Label Content="Hide Name" Grid.Row="1" Grid.Column="1" Margin="0"/>
                                                    <CheckBox Name="HideNameCheckbox" Grid.Row="1" Grid.Column="2" Margin="3" Checked="HideNameCheckboxChecked" Unchecked="HideNameCheckboxUnchecked" >
                                                        <CheckBox.LayoutTransform>
                                                            <ScaleTransform ScaleX="2" ScaleY="2" />
                                                        </CheckBox.LayoutTransform>
                                                    </CheckBox>


                                                    <Label Content="Hide Entry" Grid.Row="2" Grid.Column="1" Margin="0" />
                                                    <Border Grid.Row="2" Grid.Column="1" Margin="3,0,19,3" BorderThickness="0,0,0,2" BorderBrush="#FFA4A4A4" ToolTip="The next time this editor is opened, &#xA;this entry will be invisible (but still exist). &#xA; &#xA;You can see hidden entrys by using &#xA;the Show Hidden Entrys toggle on the hot bar. &#xA; &#xA;Also, if all entrys in a group are hidden,&#xA;the group itself will also become hidden."/>
                                                    <CheckBox Name="HideEntryCheckbox" Grid.Row="2" Grid.Column="2" Margin="3" Checked="HideEntryCheckboxChecked" Unchecked="HideEntryCheckboxUnchecked" >
                                                        <CheckBox.LayoutTransform>
                                                            <ScaleTransform ScaleX="2" ScaleY="2" />
                                                        </CheckBox.LayoutTransform>
                                                    </CheckBox>


                                                    <Label Content="Byte Size" Grid.Row="4" Grid.Column="1" Margin="0"/>
                                                    <Border Grid.Row="4" Grid.Column="1" Margin="3,0,24,3" BorderThickness="0,0,0,2" BorderBrush="#FFA4A4A4" ToolTip="Big Endian: 00 on left (0014, 002B). &#xA;Little Endian: 00 on right (1400, 2B00).&#xA;   &#xA;Most consoles use Big Endian."/>
                                                    <ComboBox x:Name="PropertiesEntryByteSizeComboBox" Grid.Row="4" Grid.Column="2" Margin="3" DropDownClosed="PropertiesEntryByteSizeComboBox_DropDownClosed" >
                                                        <ComboBoxItem Content="1 Byte"/>
                                                        <ComboBoxItem Content="2 Bytes Little Endian"/>
                                                        <ComboBoxItem Content="4 Bytes Little Endian"/>
                                                        <ComboBoxItem Content="2 Bytes Big Endian"/>
                                                        <ComboBoxItem Content="4 Bytes Big Endian"/>

                                                    </ComboBox>

                                                    <Label Content="Entry Type" Grid.Row="5" Grid.Column="1" Margin="0"/>
                                                    <ComboBox x:Name="PropertiesEntryType" Grid.Row="5" Grid.Column="2" Margin="3"  DropDownClosed="PropertiesEntryType_DropDownClosed">
                                                    </ComboBox>

                                                    <Label Content="Hex Address" Grid.Row="6" Grid.Column="1" Margin="0"/>
                                                    <TextBox x:Name="PropertiesEntryHexAddressTextbox" Grid.Row="6" Grid.Column="2" Margin="3" TextWrapping="Wrap" IsEnabled="False"/>
                                                </Grid>
                                            </DockPanel>
                                        </Border>


                                        <Border DockPanel.Dock="Top">
                                            <TabControl Name="EntryElementProperties" DockPanel.Dock="Top">
                                                <TabItem Header="NumberBox" Name="EntryTab1">
                                                    <DockPanel >
                                                        <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                                                            <DockPanel Style="{DynamicResource ContentBar}" >
                                                                <Label Content="Numberbox Properties" FontWeight="Bold" />
                                                            </DockPanel>
                                                        </Border>

                                                        <Grid DockPanel.Dock="Top">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>

                                                            </Grid.RowDefinitions>
                                                            <Label Content="Accept Negative Values?" Grid.Column="0" Grid.Row="0"  HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                            <Border Grid.Row="0" Grid.Column="0" Margin="3,0,7,3" BorderThickness="0,0,0,2" BorderBrush="#FFA4A4A4" ToolTip="When devs need negative numbers, they make values &#xA;higher then half the max byte size read as a negative. &#xA;So for a 1Byte example (where values are from 0~255)...  &#xA;(1 = +1) (255 = -1) (11 = +11) (245 = -11) (233 = -23) etc.&#xA;You should suspect very high numbers of being negative."/>
                                                            <CheckBox Name="NumberboxSignCheckbox" Grid.Column="1" Grid.Row="0"  Margin="0,3,0,0" Checked="SetNumberboxSigned" Unchecked="SetNumberboxUnsigned"  VerticalAlignment="Top" HorizontalAlignment="Left"  >
                                                                <CheckBox.LayoutTransform>
                                                                    <ScaleTransform ScaleX="2" ScaleY="2" />
                                                                </CheckBox.LayoutTransform>
                                                            </CheckBox>
                                                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"  Content="Suffix:" HorizontalAlignment="Left" Margin="0,0,0,0" VerticalAlignment="Top"/>
                                                            <Border Grid.Row="1" Grid.Column="0" Margin="3,0,170,3" BorderThickness="0,0,0,2" BorderBrush="#FFA4A4A4" ToolTip="'Suffix Text' appears at the end of a textbox. &#xA;For example, instead of 50, it can be 50% or 50$ or 50px. &#xA; &#xA;A suffix is purely cosmetic, and has no actual effect &#xA;(Meaning the suffix is ignored when saving game files). "/>
                                                            <TextBox x:Name="NumberboxSuffixTextbox" TextChanged="SuffixTextChanged" Grid.Row="1" Grid.Column="1" Margin="0,3,0,0" TextWrapping="Wrap" Text="Suffix Text" VerticalAlignment="Top" HorizontalAlignment="Stretch" />


                                                        </Grid>
                                                    </DockPanel>
                                                </TabItem>
                                                <TabItem Header="CheckBox" Name="EntryTab2" >
                                                    <DockPanel>
                                                        <Border Style="{DynamicResource ContentBorder}" DockPanel.Dock="Top">
                                                            <DockPanel Style="{DynamicResource ContentBar}"  >
                                                                <Label Content="Checkbox Properties" FontWeight="Bold" />
