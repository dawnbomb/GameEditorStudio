<Window x:Class="GameEditorStudio.Tutorial"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameEditorStudio"
        mc:Ignorable="d"
        Title="Tutorial" Height="800" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1"/>
            <RowDefinition Height="433*"/>
            <RowDefinition Height="26.04"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Grid.Row="1" Grid.RowSpan="1" Margin="5,5,5,5">
            <Border  DockPanel.Dock="Bottom"  Height="150" Margin="0,10,0,0">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Style="{DynamicResource ContentBar}" LastChildFill="False">
                        <Label Content="Info" FontWeight="Bold"/>
                        <Button Name="SaveWikiButton" Content="Save Wiki" Width="110" Click="ButtonSaveWiki" />
                        <Label Name="ItemTypeLabel" Content="Info2" FontWeight="Bold" DockPanel.Dock="Right"/>
                    </DockPanel>
                    <DockPanel LastChildFill="False">
                        <TextBox Name="CategoryNameBox" DockPanel.Dock="Top" MinWidth="120" Margin="5" KeyDown="CategoryNameBoxKeyDown"/>
                        <TextBox DockPanel.Dock="Top" MinWidth="120" Margin="5" Name="DocumentNameBox" KeyDown="DocumentNameBoxKeyDown" />
                        <DockPanel>
                            <Button x:Name="ButtonEditMode" Content="Edit Mode" Width="120" Margin="3" DockPanel.Dock="Right" Click="ButtonEditModeClick"/>
                            <Button x:Name="ButtonWriteMode" Content="Write" Width="75" Margin="3" DockPanel.Dock="Right" Click="ButtonWriteModeClick" Visibility="Collapsed"/>
                            <Button x:Name="ButtonReadMode" Content="Read" Width="75" Margin="3" DockPanel.Dock="Right" Click="ButtonReadModeClick" Visibility="Collapsed"/>
                        </DockPanel>
                    </DockPanel>
                    <!--<TreeView x:Name="TreeOfHistory" DockPanel.Dock="Top" SelectedItemChanged="CategoryChanged" >

                    </TreeView>-->

                </DockPanel>
            </Border>

            <Border  DockPanel.Dock="Top"  >
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Style="{DynamicResource ContentBar}" LastChildFill="False">
                        <Label Content="Categories" FontWeight="Bold"/>
                        <Button Name="ButtonNewCategory" Content=" New Folder " DockPanel.Dock="Right"  Click="NewWikiCategory" Margin="3"/>                        
                    </DockPanel>


                    <TreeView x:Name="TreeOfCategorys" DockPanel.Dock="Top" SelectedItemChanged="CategoryChanged" Height="250">

                    </TreeView>

                </DockPanel>
            </Border>



            <Border  DockPanel.Dock="Top" Margin="0,10,0,0" >
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Style="{DynamicResource ContentBar}" LastChildFill="False">
                        <Label Content="Documents" FontWeight="Bold"/>
                        <Button Name="ButtonNewDocument" Content=" New Document " DockPanel.Dock="Right" Click="NewWikiTopic" Margin="3"/>
                    </DockPanel>


                    <TreeView x:Name="TreeOfDocuments" SelectedItemChanged="DocumentChanged" MinHeight="200">

                    </TreeView>
                </DockPanel>
            </Border>


        </DockPanel>

        <DockPanel Grid.Column="1" Grid.Row="1" Grid.RowSpan="1" Margin="5,5,5,5">
            

            
        </DockPanel>

        <ContentControl  Grid.Column="2" Grid.Row="1" Grid.RowSpan="1" Margin="5,5,5,5">
            <DockPanel>
                <DockPanel Style="{DynamicResource ContentBar}" DockPanel.Dock="Top" Background="#FF272727"  >
                    <Label Name="DocumentLabel" Content="Info" FontWeight="Bold" FontSize="30"  DockPanel.Dock="Left" HorizontalAlignment="Center" HorizontalContentAlignment="Center" />                    
                </DockPanel>
                <Separator Width="Auto" DockPanel.Dock="Top" Style="{DynamicResource SeparatorSolid}"/>
                <ScrollViewer Name="PatchnoteScrollViewer" VerticalScrollBarVisibility="Auto" Background="#FF353535"  >
                    <StackPanel Background="{x:Null}">
                        <StackPanel Name="PatchnotePanel" Background="Transparent" Margin="5,10,5,10">
                            <TextBlock x:Name="DocumentReadBox" Margin="15,10,15,10" FontSize="20" FontFamily="{DynamicResource AppFont}" TextWrapping="Wrap" Foreground="#FFE6E6E6"/>
                        </StackPanel>
                        <TextBox x:Name="DocumentEditBox" TextChanged="TextboxTextChanged" Margin="10" TextWrapping="Wrap" AcceptsReturn="True">

                        </TextBox>
                    </StackPanel>
                        

                </ScrollViewer>
            </DockPanel>

        </ContentControl>

        <Label Grid.Column="2" Content="Next:  Tutorial History.         Later:   Related Topics." HorizontalAlignment="Left" Margin="0,0,0,0" Grid.Row="2" VerticalAlignment="Center" Height="32" Width="831"/>


    </Grid>
</Window>
