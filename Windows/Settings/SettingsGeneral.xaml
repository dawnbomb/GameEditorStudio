<UserControl x:Class="GameEditorStudio.SettingsGeneral"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GameEditorStudio"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <TabControl Margin="10,0,0,0" Background="DimGray">
            <TabItem Header="General" Background="Transparent">
                <Grid Background="Transparent">
                    <StackPanel Margin="10" Background="Transparent">
                        <CheckBox Content="Enable Auto-Save" Margin="0,0,0,5"/>
                        <CheckBox Content="Show Tooltips" Margin="0,0,0,5"/>
                        <CheckBox Content="Enable Dark Mode" Margin="0,0,0,5"/>
                        <CheckBox Content="Show Line Numbers" Margin="0,0,0,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!--<TabItem Header="Dummy" Background="Transparent"/>-->
        </TabControl>
    </Grid>
    
</UserControl>
