<Window x:Class="GameEditorStudio.UserSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameEditorStudio"
        mc:Ignorable="d"
        Title="Game Editor Studio Settings" Height="650" Width="650">
    <DockPanel >
        <Button Content="Close" HorizontalAlignment="Right" Margin="10,0,10,10" Width="100" Height="32" VerticalAlignment="Top" Click="ButtonBackClick" DockPanel.Dock="Bottom"/>
        <Grid Margin="15,15,15,10" Style="{DynamicResource GridList}">
            <TabControl  TabStripPlacement="Left"  >
                <TabItem Header="General" FontSize="20" Background="Transparent" >
                    <local:SettingsGeneral DockPanel.Dock="Top"  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                    
                </TabItem>


                <TabItem Header="Themes" FontSize="20" Background="Transparent">
                    <TabControl Margin="10,0,0,0" >
                        <TabItem Header="General" Background="Transparent">
                            <Grid>
                                <DockPanel HorizontalAlignment="Left" Width="145" Margin="8,0,0,0">
                                    <Label Content="Color Themes" HorizontalAlignment="Left" Margin="9,3,0,0" VerticalAlignment="Top" DockPanel.Dock="Top"/>
                                    <Button Content="Copy Theme" Margin="0,3,0,0" DockPanel.Dock="Bottom" Click="ButtonNewThemeClick"/>
                                    <TreeView Name="ColorThemeTree"  SelectedItemChanged="ColorThemeTreeSelectionChanged" DockPanel.Dock="Top" />
                                </DockPanel>

                                <Label Content="Note: This requires restart?" HorizontalAlignment="Left" Margin="310,0,0,0" VerticalAlignment="Top" DockPanel.Dock="Top"/>
                                <Border Margin="156,36,10,10">
                                    <DataGrid x:Name="ColorDataTable" AutoGenerateColumns="False" IsReadOnly="True" >

                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Element Name" Binding="{Binding Name}" Width="170" />
                                            <DataGridTemplateColumn Header="Text" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Text, Converter={StaticResource ColorTextConverter}}"
Background="{Binding Text, Converter={StaticResource StringToBrushConverter}}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Back" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Back, Converter={StaticResource ColorTextConverter}}"
Background="{Binding Back, Converter={StaticResource StringToBrushConverter}}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Border" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Border, Converter={StaticResource ColorTextConverter}}"
Background="{Binding Border, Converter={StaticResource StringToBrushConverter}}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Other" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Border, Converter={StaticResource ColorTextConverter}}" Background="{Binding Border, Converter={StaticResource StringToBrushConverter}}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Notes" Binding="{Binding Note}" Width="200" />
                                        </DataGrid.Columns>
                                    </DataGrid>




                                </Border>
                            </Grid>

                        </TabItem>
                        <!--<TabItem Header="Dummy" Background="Transparent"/>-->
                    </TabControl>
                </TabItem>
                <Separator Width="50" Height="50"/>
                <TabItem Header="Data Table" FontSize="20" Background="Transparent">
                    <local:SettingsDataTable DockPanel.Dock="Top" />
                </TabItem>

                <!--<TabItem Header="Dummy" Background="Transparent">
                <TabControl Margin="10,0,0,0" >
                    <TabItem Header="General" Background="Transparent">
                        <Grid>
                            
                        </Grid>

                    </TabItem>
                    -->
                <!--<TabItem Header="Dummy" Background="Transparent">
                        <Grid>

                        </Grid>
                    </TabItem>-->
                <!--
                </TabControl>
            </TabItem>-->
            </TabControl>
        </Grid>
        


    </DockPanel>
</Window>
