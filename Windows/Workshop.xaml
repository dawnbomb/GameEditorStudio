<UserControl x:Class="GameEditorStudio.Workshop"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"        
        xmlns:local="clr-namespace:GameEditorStudio"
        mc:Ignorable="d"
        d:DesignHeight="750" d:DesignWidth="1400">
    <!--Height="900" Width="1580"-->




    <Grid x:Name="GridBack" Style="{DynamicResource BorderGrid}" Background="#333333">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="38"/>
            <RowDefinition/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="0"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition/>            
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>


        <!--The Top Bar-->
        <DockPanel Grid.Column="0" Grid.ColumnSpan="5"  Grid.RowSpan="1"  Margin="0,0,0,0" Style="{DynamicResource AppOther}"  >
            <local:TopMenu x:Name="MenusForToolsAndEvents"  Margin="10,0,0,0"  DockPanel.Dock="Right"  Grid.Column="0" Grid.ColumnSpan="5"  Grid.RowSpan="1"/>
        </DockPanel>

        <!--The Tabs Bar (For the editors tabs, and the home tab)-->
        <Grid DockPanel.Dock="Top"   Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,0,0,0"  Style="{DynamicResource AppOtherGrid}" >
            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,0,0,0" BorderThickness="0,2,0,0"  Grid.RowSpan="1" VerticalAlignment="Bottom" >
                <Border BorderThickness="0,2,0,0" BorderBrush="#FF575757">

                </Border>
            </Border>
            <DockPanel Background="Transparent" >
                <Button DockPanel.Dock="Left" x:Name="ButtonHome"     Click="ButtonHome_Click" Margin="10,0,4,0"  Style="{DynamicResource ButtonEditorTab}">
                    <Label Content=" ⛫ Home " />
                </Button>
                <ScrollViewer  DockPanel.Dock="Left" x:Name="EditorBarScrollViewer" Background="Transparent" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PreviewMouseWheel="EditorBarMouseWheel" >
                    <!--Background="#FF272A2B"-->
                    <DockPanel x:Name="EditorBar" Background="{x:Null}" LastChildFill="False" />
                </ScrollViewer>
            </DockPanel>
        </Grid>



        <!--The Main Area for each Editor-->
        <Grid x:Name="MidGrid"  Grid.Column="1" Grid.Row="3" Grid.RowSpan="2" Grid.ColumnSpan="1" Background="#FF150303" >

            <!--The Home Tab-->
            <local:Home x:Name="HomeControl" Grid.Column="1" Grid.Row="1" />

        </Grid>


    </Grid>
</UserControl>
